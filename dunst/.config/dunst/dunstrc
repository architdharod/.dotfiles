[global]
    monitor        = 0
    follow         = mouse
    width          = 320
    height         = 300
    origin         = top-right
    offset         = 12x48
    notification_limit = 5

    progress_bar             = true
    progress_bar_height      = 8
    progress_bar_frame_width = 1
    progress_bar_min_width   = 200
    progress_bar_max_width   = 280

    padding            = 10
    horizontal_padding = 12
    frame_width        = 2
    frame_color        = "#7aa2f7"
    corner_radius      = 6
    separator_height   = 1
    separator_color    = "#292e42"

    font       = JetBrainsMono Nerd Font 10
    line_height = 2
    markup     = full
    format     = "<b>%s</b>\n%b"
    alignment  = left
    word_wrap  = yes
    ellipsize  = middle

    show_age_threshold  = 60
    stack_duplicates    = true
    hide_duplicate_count = false
    show_indicators     = yes

    dmenu  = /usr/bin/rofi -p dunst
    browser = /usr/bin/xdg-open

    mouse_left_click   = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click  = close_all

[urgency_low]
    background  = "#1a1b26"
    foreground  = "#c0caf5"
    frame_color = "#292e42"
    timeout     = 4

[urgency_normal]
    background  = "#1a1b26"
    foreground  = "#c0caf5"
    frame_color = "#7aa2f7"
    timeout     = 8

[urgency_critical]
    background  = "#1a1b26"
    foreground  = "#f7768e"
    frame_color = "#f7768e"
    timeout     = 0
